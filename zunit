#!/usr/bin/env -S java --source 25

/**
 * zunit - Minimal, zero-dependency test runner for Java.
 *
 * Discovers *Test.java source files and runs each directly via
 * java --source 25. No compilation step, no JUnit, no dependencies.
 *
 * Test convention:
 *   - Test files: name ends with "Test.java"
 *   - Each test file is a self-contained Java source script
 *   - Must have a void main() (implicit in Java 25)
 *   - Failure: any thrown exception or non-zero exit = failed
 *
 * Test source auto-detection (in order):
 *   src/test/java/                        (Maven)
 *   test/                                 (simple)
 *   .                                     (fallback)
 *
 * Classpath auto-detection (in order):
 *   .zb config (jar.dir + jar.file.name)  (zb config)
 *   zbo/app.jar                           (zb default)
 *   target/classes                        (Maven)
 *   classes/                              (simple)
 *   .                                     (fallback)
 *
 * Examples:
 *   zunit                                 # auto-detect and run
 *   zunit -cp:target/classes              # explicit classpath
 *   zunit -tp:test/                       # explicit test path
 *
 * Logging based on https://github.com/AdamBien/zcl
 */

String version = "2026-04-08.3";

enum Log {

    ERROR(Color.BRIGHT_RED, System.err),
    INFO(Color.BRIGHT_GREEN, System.out),
    WARNING(Color.WARM_YELLOW, System.out),
    PROGRESS(Color.WARM_YELLOW, System.out),
    DEBUG(Color.SOFT_PURPLE, System.out);

    PrintStream out;

    enum Color {
        WARM_YELLOW("\033[38;5;220m"),
        BRIGHT_RED("\033[38;5;196m"),
        BRIGHT_GREEN("\033[38;5;46m"),
        SOFT_PURPLE("\033[38;5;129m");

        String code;

        Color(String code) {
            this.code = code;
        }
    }

    String value;
    static final String RESET = "\u001B[0m";

    Log(Color color, PrintStream out) {
        this.value = color.code + "%s" + RESET;
        this.out = out;
    }

    void out(String message) {
        this.out.println(this.value.formatted(message));
    }

    static void info(String message) {
        INFO.out(message);
    }

    static void debug(String message) {
        DEBUG.out(message);
    }

    static void error(String message) {
        ERROR.out(message);
    }

    static void progress(String message) {
        PROGRESS.out.print(PROGRESS.value.formatted(message));
    }

    static void stop(String message) {
        ERROR.out(message);
        System.exit(1);
    }
}

enum Arg {
    HELP("-help", "Show this help"),
    CP("-cp", "Override classpath for main classes"),
    TP("-tp", "Override test source path"),
    VERBOSE("-verbose", "Show debug info");

    final String option;
    final String description;

    Arg(String option, String description) {
        this.option = option;
        this.description = description;
    }

    boolean matches(String value) {
        return this.option.equals(value)
            || value.startsWith(this.option + ":");
    }

    static Arg from(String value) {
        return Stream.of(values())
            .filter(a -> a.matches(value))
            .findFirst()
            .orElse(null);
    }

    static String usage() {
        return Stream.of(values())
            .map(a -> {
                var label = switch (a) {
                    case CP -> a.option + ":<path>";
                    case TP -> a.option + ":<path>";
                    default -> a.option;
                };
                return "  %-20s %s".formatted(label, a.description);
            })
            .collect(Collectors.joining("\n"));
    }
}

record Config(String classpath, String testPath, boolean verbose) {}

record ZbConfig(String jarDir, String jarFileName) {
    static final Path ZB_FILE = Path.of(".zb");
    static final String DISCOVERED = "<discovered by zb>";
    static final String TEMP_DIR = "<temp.dir>";

    String jarPath() {
        return Path.of(jarDir, jarFileName).toString();
    }

    static ZbConfig load() {
        if (!Files.exists(ZB_FILE)) return null;
        var properties = new Properties();
        try (var reader = new java.io.FileReader(ZB_FILE.toFile())) {
            properties.load(reader);
            var jarDir = resolve(properties, "jar.dir");
            var jarFileName = resolve(properties, "jar.file.name");
            if (jarDir != null && jarFileName != null)
                return new ZbConfig(jarDir, jarFileName);
        } catch (IOException e) {
            // ignore, fall through to auto-detection
        }
        return null;
    }

    static String resolve(Properties properties, String key) {
        var value = properties.getProperty(key);
        if (value == null || value.equals(DISCOVERED) || value.equals(TEMP_DIR))
            return null;
        return value;
    }
}

record TestResult(String fileName, boolean passed, String output) {}

void main(String... args) {
    var config = parseArgs(args);

    Log.info("zunit " + version);

    var classpath = resolveClasspath(config.classpath(), config.verbose());
    var testFiles = discoverTests(config.testPath(), config.verbose());

    if (testFiles.isEmpty()) {
        Log.error("No test files found");
        System.exit(2);
    }

    var results = runTests(testFiles, classpath, config.verbose());
    reportResults(results);
}

Config parseArgs(String[] args) {
    String classpath = null;
    String testPath = null;
    var verbose = false;

    for (var arg : args) {
        switch (Arg.from(arg)) {
            case HELP -> printUsage();
            case CP -> classpath = extractValue(arg);
            case TP -> testPath = extractValue(arg);
            case VERBOSE -> verbose = true;
            case null -> {
                if (arg.startsWith("-")) Log.stop("Unknown option: " + arg);
                Log.stop("Unknown argument: " + arg);
            }
        }
    }
    return new Config(classpath, testPath, verbose);
}

String extractValue(String arg) {
    var idx = arg.indexOf(":");
    if (idx < 0 || idx + 1 >= arg.length()) {
        Log.stop("Missing value for " + arg);
    }
    return arg.substring(idx + 1);
}

String resolveClasspath(String explicitCp, boolean verbose) {
    var cp = explicitCp != null ? explicitCp : detectClasspath();
    if (verbose) Log.debug("Classpath: " + cp);
    return cp;
}

String detectClasspath() {
    // zb configuration file
    var zbConfig = ZbConfig.load();
    if (zbConfig != null) {
        var jarPath = Path.of(zbConfig.jarPath());
        if (Files.exists(jarPath)) return jarPath.toString();
    }

    // zb output (default)
    var zbJar = Path.of("zbo", "app.jar");
    if (Files.exists(zbJar)) return zbJar.toString();

    // Maven layout
    if (Files.isDirectory(Path.of("target", "classes")))
        return "target/classes";

    // Simple layout
    if (Files.isDirectory(Path.of("classes")))
        return "classes";

    return ".";
}

List<Path> discoverTests(String explicitPath, boolean verbose) {
    var searchDir = explicitPath != null
        ? Path.of(explicitPath)
        : TestPath.detect();

    if (verbose) Log.debug("Test path: " + searchDir);

    if (!Files.isDirectory(searchDir)) {
        Log.error("Test path not found: " + searchDir);
        return List.of();
    }

    try (var paths = Files.walk(searchDir)) {
        var tests = paths
            .filter(p -> p.getFileName().toString().endsWith("Test.java"))
            .sorted()
            .toList();
        if (verbose) tests.forEach(t -> Log.debug("Found: " + t));
        return tests;
    } catch (IOException e) {
        Log.error("Failed to scan: " + searchDir + " (" + e.getMessage() + ")");
        return List.of();
    }
}

enum TestPath {
    MAVEN("src/test/java"),
    SIMPLE("test"),
    FALLBACK(".");

    final Path path;

    TestPath(String path) {
        this.path = Path.of(path);
    }

    static Path detect() {
        return Stream.of(values())
            .map(tp -> tp.path)
            .filter(Files::isDirectory)
            .findFirst()
            .orElse(FALLBACK.path);
    }
}

record RunningTest(String fileName, Process process) {}

static final String[] SPINNER_FRAMES = {"⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"};

Thread startSpinner(String label) {
    return Thread.startVirtualThread(() -> {
        var i = 0;
        while (!Thread.currentThread().isInterrupted()) {
            var frame = SPINNER_FRAMES[i++ % SPINNER_FRAMES.length];
            Log.progress("\r  " + frame + " " + label);
            try { Thread.sleep(80); } catch (InterruptedException e) { break; }
        }
        Log.progress("\r" + " ".repeat(label.length() + 6) + "\r");
    });
}

void stopSpinner(Thread spinner) {
    spinner.interrupt();
    try { spinner.join(); } catch (InterruptedException e) {}
}

List<TestResult> runTests(List<Path> testFiles, String classpath, boolean verbose) {
    // Start all test processes concurrently
    var running = new ArrayList<RunningTest>();
    for (var testFile : testFiles) {
        var command = List.of("java", "-ea", "--source", "25", "--class-path", classpath, testFile.toString());
        if (verbose) Log.debug("Command: " + String.join(" ", command));

        try {
            var process = new ProcessBuilder(command)
                .redirectErrorStream(true)
                .start();
            var fileName = testFile.getFileName().toString().replace(".java", "");
            running.add(new RunningTest(fileName, process));
        } catch (IOException e) {
            var fileName = testFile.getFileName().toString().replace(".java", "");
            running.add(new RunningTest(fileName, null));
        }
    }

    // Show launched tests
    running.forEach(test -> Log.info("  ⧖ " + test.fileName()));
    System.out.println();

    // Collect results with spinner feedback
    var results = new ArrayList<TestResult>();
    for (var test : running) {
        var spinner = startSpinner(test.fileName());
        var result = collectResult(test);
        stopSpinner(spinner);
        results.add(result);
        printResult(result);
    }
    return results;
}

TestResult collectResult(RunningTest test) {
    if (test.process() == null)
        return new TestResult(test.fileName(), false, "Failed to start");
    try {
        var output = new String(test.process().getInputStream().readAllBytes());
        var exitCode = test.process().waitFor();
        return new TestResult(test.fileName(), exitCode == 0, output.strip());
    } catch (IOException | InterruptedException e) {
        return new TestResult(test.fileName(), false, e.getMessage());
    }
}

void printResult(TestResult result) {
    if (result.passed()) {
        Log.info("  ✓ " + result.fileName());
    } else {
        Log.error("  ✗ " + result.fileName());
        if (!result.output().isEmpty()) {
            result.output().lines().forEach(line ->
                Log.error("    " + line));
        }
    }
}

void reportResults(List<TestResult> results) {
    var passed = results.stream().filter(TestResult::passed).count();
    var failed = results.size() - passed;

    System.out.println();
    if (failed == 0) {
        Log.info("%d tests passed".formatted(results.size()));
    } else {
        Log.error("%d of %d tests failed".formatted(failed, results.size()));
    }
    System.exit(failed > 0 ? 1 : 0);
}

void printUsage() {
    IO.println("""
        zunit - Zero-dependency test runner

        Usage: zunit [options]

        Options:
        %s

        Test convention:
          - Test files: *Test.java source files
          - Each file is a self-contained Java script with void main()
          - Failure: any thrown exception or non-zero exit = failed

        Test source auto-detection:
          src/test/java/     Maven layout
          test/              Simple layout
          .                  Fallback

        Classpath auto-detection:
          .zb config         zb configuration (jar.dir + jar.file.name)
          zbo/app.jar        zb default
          target/classes     Maven output
          classes/           Simple layout
          .                  Fallback

        Examples:
          zunit                               Auto-detect and run all tests
          zunit -cp:zbo/app.jar               Explicit classpath
          zunit -tp:test/                     Explicit test source path
          zunit -verbose                      Show debug output
        """.formatted(Arg.usage()));
    System.exit(0);
}
