#!/usr/bin/env -S java --source 25

/**
 * zunit - Minimal, zero-dependency test runner for Java.
 *
 * Discovers test classes on the classpath and executes all public
 * void zero-arg methods via reflection. No JUnit required.
 *
 * Test convention:
 *   - Test classes: name ends with "Test", public no-arg constructor
 *   - Test methods: public void, zero arguments
 *   - Lifecycle: setUp() before each test, tearDown() after (optional)
 *   - Failure: any thrown exception marks the test as failed
 *
 * Classpath auto-detection (in order):
 *   target/test-classes + target/classes  (Maven)
 *   classes/                              (simple)
 *   .                                     (fallback)
 *
 * Examples:
 *   zunit                                 # auto-detect and run
 *   zunit -cp:target/test-classes         # explicit classpath
 *
 * Logging based on https://github.com/AdamBien/zcl
 */

import java.lang.reflect.Method;
import java.lang.reflect.Modifier;
import java.net.URL;
import java.net.URLClassLoader;

String version = "2026-04-06.1";

static final Set<String> EXCLUDED_METHODS = Set.of("setUp", "tearDown", "main");

enum Log {

    ERROR(Color.BRIGHT_RED, System.err),
    INFO(Color.BRIGHT_GREEN, System.out),
    WARNING(Color.WARM_YELLOW, System.out),
    DEBUG(Color.SOFT_PURPLE, System.out);

    PrintStream out;

    enum Color {
        WARM_YELLOW("\033[38;5;220m"),
        BRIGHT_RED("\033[38;5;196m"),
        BRIGHT_GREEN("\033[38;5;46m"),
        SOFT_PURPLE("\033[38;5;129m");

        String code;

        Color(String code) {
            this.code = code;
        }
    }

    String value;
    static final String RESET = "\u001B[0m";

    Log(Color color, PrintStream out) {
        this.value = color.code + "%s" + RESET;
        this.out = out;
    }

    void out(String message) {
        this.out.println(this.value.formatted(message));
    }

    static void info(String message) {
        INFO.out(message);
    }

    static void debug(String message) {
        DEBUG.out(message);
    }

    static void error(String message) {
        ERROR.out(message);
    }

    static void stop(String message) {
        ERROR.out(message);
        System.exit(1);
    }
}

enum Arg {
    HELP("-help", "Show this help"),
    CP("-cp", "Override classpath (colon-separated)"),
    VERBOSE("-verbose", "Show debug info");

    final String option;
    final String description;

    Arg(String option, String description) {
        this.option = option;
        this.description = description;
    }

    boolean matches(String value) {
        return this.option.equals(value)
            || value.startsWith(this.option + ":");
    }

    static Arg from(String value) {
        return Stream.of(values())
            .filter(a -> a.matches(value))
            .findFirst()
            .orElse(null);
    }

    static String usage() {
        return Stream.of(values())
            .map(a -> {
                var label = switch (a) {
                    case CP -> a.option + ":<path>";
                    default -> a.option;
                };
                return "  %-20s %s".formatted(label, a.description);
            })
            .collect(Collectors.joining("\n"));
    }
}

record Config(String classpath, boolean verbose) {}

record TestResult(String className, String methodName, boolean passed, String message) {}

void main(String... args) {
    var config = parseArgs(args);

    Log.info("zunit " + version);

    var classpath = resolveClasspath(config.classpath(), config.verbose());
    var testClasses = discoverTests(classpath, config.verbose());

    if (testClasses.isEmpty()) {
        Log.error("No test classes found");
        System.exit(2);
    }

    var results = executeTests(testClasses, config.verbose());
    reportResults(results);
}

Config parseArgs(String[] args) {
    String classpath = null;
    var verbose = false;

    for (var arg : args) {
        switch (Arg.from(arg)) {
            case HELP -> printUsage();
            case CP -> classpath = extractValue(arg);
            case VERBOSE -> verbose = true;
            case null -> {
                if (arg.startsWith("-")) Log.stop("Unknown option: " + arg);
                Log.stop("Unknown argument: " + arg);
            }
        }
    }
    return new Config(classpath, verbose);
}

String extractValue(String arg) {
    var idx = arg.indexOf(":");
    if (idx < 0 || idx + 1 >= arg.length()) {
        Log.stop("Missing value for " + arg);
    }
    return arg.substring(idx + 1);
}

String resolveClasspath(String explicitCp, boolean verbose) {
    var entries = explicitCp != null
        ? List.of(explicitCp.split(File.pathSeparator))
        : detectClasspath();

    var cp = String.join(File.pathSeparator, entries);
    if (verbose) Log.debug("Classpath: " + cp);
    return cp;
}

List<String> detectClasspath() {
    var entries = new ArrayList<String>();

    // Maven layout
    if (Files.isDirectory(Path.of("target", "test-classes"))) {
        entries.add("target/test-classes");
        if (Files.isDirectory(Path.of("target", "classes")))
            entries.add("target/classes");
        return entries;
    }
    // Simple layout
    if (Files.isDirectory(Path.of("classes"))) {
        entries.add("classes");
        return entries;
    }

    // Fallback
    entries.add(".");
    return entries;
}

List<Class<?>> discoverTests(String classpath, boolean verbose) {
    var dirs = Stream.of(classpath.split(File.pathSeparator))
        .map(Path::of)
        .filter(Files::isDirectory)
        .toList();

    var urls = dirs.stream()
        .map(d -> {
            try { return d.toUri().toURL(); }
            catch (Exception e) { return null; }
        })
        .filter(u -> u != null)
        .toArray(URL[]::new);

    var loader = new URLClassLoader(urls, Thread.currentThread().getContextClassLoader());
    var testClasses = new ArrayList<Class<?>>();

    for (var dir : dirs) {
        try (var paths = Files.walk(dir)) {
            paths.filter(p -> p.toString().endsWith(".class"))
                .forEach(p -> {
                    var relative = dir.relativize(p).toString();
                    var className = relative
                        .replace(File.separatorChar, '.')
                        .replaceAll("\\.class$", "");

                    if (!className.endsWith("Test")) return;

                    try {
                        var clazz = loader.loadClass(className);
                        if (!Modifier.isAbstract(clazz.getModifiers())
                            && hasPublicNoArgConstructor(clazz)) {
                            testClasses.add(clazz);
                            if (verbose) Log.debug("Found: " + className);
                        }
                    } catch (Throwable e) {
                        if (verbose) Log.debug("Skip: " + className + " (" + e.getMessage() + ")");
                    }
                });
        } catch (IOException e) {
            Log.error("Failed to scan: " + dir + " (" + e.getMessage() + ")");
        }
    }

    return testClasses;
}

boolean hasPublicNoArgConstructor(Class<?> clazz) {
    try {
        clazz.getDeclaredConstructor();
        return Modifier.isPublic(clazz.getModifiers());
    } catch (NoSuchMethodException e) {
        return false;
    }
}

List<Method> testMethods(Class<?> clazz) {
    return Stream.of(clazz.getDeclaredMethods())
        .filter(m -> Modifier.isPublic(m.getModifiers()))
        .filter(m -> !Modifier.isStatic(m.getModifiers()))
        .filter(m -> m.getParameterCount() == 0)
        .filter(m -> m.getReturnType() == void.class)
        .filter(m -> !EXCLUDED_METHODS.contains(m.getName()))
        .toList();
}

List<TestResult> executeTests(List<Class<?>> testClasses, boolean verbose) {
    var results = new ArrayList<TestResult>();

    for (var clazz : testClasses) {
        var methods = testMethods(clazz);
        if (methods.isEmpty()) continue;

        Log.info(clazz.getSimpleName());
        var setUp = findLifecycleMethod(clazz, "setUp");
        var tearDown = findLifecycleMethod(clazz, "tearDown");

        for (var method : methods) {
            var result = executeTest(clazz, method, setUp, tearDown);
            results.add(result);
            printResult(result);
        }
    }
    return results;
}

TestResult executeTest(Class<?> clazz, Method method, Method setUp, Method tearDown) {
    try {
        var instance = clazz.getDeclaredConstructor().newInstance();
        if (setUp != null) setUp.invoke(instance);
        method.invoke(instance);
        if (tearDown != null) tearDown.invoke(instance);
        return new TestResult(clazz.getName(), method.getName(), true, null);
    } catch (Throwable e) {
        var cause = e.getCause() != null ? e.getCause() : e;
        return new TestResult(clazz.getName(), method.getName(), false, cause.toString());
    }
}

Method findLifecycleMethod(Class<?> clazz, String name) {
    try {
        var m = clazz.getDeclaredMethod(name);
        return Modifier.isPublic(m.getModifiers()) ? m : null;
    } catch (NoSuchMethodException e) {
        return null;
    }
}

void printResult(TestResult result) {
    if (result.passed()) {
        Log.info("  ✓ " + result.methodName());
    } else {
        Log.error("  ✗ " + result.methodName() + " — " + result.message());
    }
}

void reportResults(List<TestResult> results) {
    var passed = results.stream().filter(TestResult::passed).count();
    var failed = results.size() - passed;

    System.out.println();
    if (failed == 0) {
        Log.info("%d tests passed".formatted(results.size()));
    } else {
        Log.error("%d of %d tests failed".formatted(failed, results.size()));
    }
    System.exit(failed > 0 ? 1 : 0);
}

void printUsage() {
    IO.println("""
        zunit - Zero-dependency test runner

        Usage: zunit [options]

        Options:
        %s

        Test convention:
          - Test classes: name ends with "Test", public no-arg constructor
          - Test methods: public void, zero arguments
          - Lifecycle: setUp() before each, tearDown() after (optional)
          - Failure: any thrown exception marks the test as failed

        Examples:
          zunit                               Auto-detect and run all tests
          zunit -cp:target/test-classes       Explicit classpath
          zunit -verbose                      Show debug output
        """.formatted(Arg.usage()));
    System.exit(0);
}
